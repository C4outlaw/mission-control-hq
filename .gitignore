# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# generated runtime assets
/public/audio/*.wav
/tmp-whisper-test.*
/data/transcripts/tmp-whisper-test.*

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/models/piper/*.onnx

# dev server logs
dev.log
dev.err

# preserved originals (not needed in production)
/public/assets/work/beach-bucket-design/breakfast/_pre-enhance-backup
/public/assets/work/beach-bucket-design/drinks/_pre-rembg
/public/assets/work/beach-bucket-design/drinks/_pre-patch-backup
